#cloud-config
# Rendered by cmd/verify-mseg-tester -- do not hand-edit the uploaded
# snippet, edit this template and re-run `verify-mseg-tester create`
# instead.
#
# This is the same bootstrap the "real" deployment uses (see
# cloud-init/user-data.yaml): fetch the mseg-tester binary from the public
# software repo, run `mseg-tester deploy`, reboot into the first cycle.
# The one addition here is SSH access for a human to inspect a disposable
# verify VM -- the production cloud-init deliberately has no user/SSH
# access at all.

hostname: {{.Hostname}}

package_update: true
package_upgrade: true    # dist-upgrade everything already installed on first boot, not just refresh the apt index -- see cloud-init/user-data.yaml's twin of this file, kept in parity
packages:
  - ca-certificates
  - git                   # for the local checkout mseg-tester-bootstrap.sh clones and internal/selfupdate keeps updated
  - wpasupplicant         # required for netplan's wifis: stanza -- see the segment "wifi-*" entries in -config-file/ConfigYAML above
  - linux-firmware        # the mt7921e driver (MediaTek MT7922) needs firmware blobs not always current on the base
                          # cloud image -- confirmed live: "Direct firmware load for mediatek/WIFI_MT7922_patch_mcu_1_1_hdr.bin
                          # failed with error -2 (ENOENT)" / "hardware init failed" until this is upgraded/(re)installed

users:
  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: {{if .ConsolePassword}}false{{else}}true{{end}}
{{- if .SSHAuthorizedKey}}
    ssh_authorized_keys:
      - {{.SSHAuthorizedKey}}
{{- end}}
{{- if .ConsolePassword}}

# Plaintext here is fine -- cloud-init hashes it before writing
# /etc/shadow, it's never stored or transmitted as-is. This is for
# logging in on Proxmox's serial/VNC console (--serial0 socket --vga
# serial0 below), independent of SSH -- ssh_pwauth is deliberately NOT
# set, so SSH itself still requires -ssh-key-file's key.
chpasswd:
  expire: false
  list: |
    ubuntu:{{.ConsolePassword}}
{{- end}}

write_files:
  # Initial netplan: the trunk NIC plus the update segment only -- same
  # shape mseg-tester itself writes on every subsequent cycle (see
  # internal/netplan.Write). This copy only matters for getting from
  # cloud-init to that first `mseg-tester run`, which overwrites it
  # wholesale.
{{- if and .NativeSegment (eq .NativeSegment .UpdateSegment)}}
  #
  # UpdateSegment IS NativeSegment here -- its traffic arrives UNTAGGED
  # directly on {{.TrunkIface}}, not on a VLAN sub-interface, so
  # {{.TrunkIface}} is configured directly (see internal/netplan.Write's
  # native branch).
  - path: /etc/netplan/90-mseg-tester.yaml
    permissions: "0600"
    content: |
      network:
        version: 2
        ethernets:
          {{.TrunkIface}}:
            dhcp4: true
            dhcp6: false
            accept-ra: true
            link-local: [ipv4, ipv6]
{{- else}}
  #
  # "optional: true" on the trunk interface itself tells
  # systemd-networkd-wait-online not to block boot waiting for IT
  # specifically to become "routable" -- it never will, it's a pure VLAN
  # carrier with no address of its own. Without this, boot can hang for a
  # long time (observed: "no limit" on systemd-networkd-wait-online.service).
  - path: /etc/netplan/90-mseg-tester.yaml
    permissions: "0600"
    content: |
      network:
        version: 2
        ethernets:
          {{.TrunkIface}}:
            dhcp4: false
            dhcp6: false
            optional: true
        vlans:
          {{.TrunkIface}}.{{.UpdateSegment}}:
            id: {{.UpdateSegment}}
            link: {{.TrunkIface}}
            dhcp4: true
            dhcp6: false
            accept-ra: true
            link-local: [ipv4, ipv6]
{{- end}}

  # Local, rare-to-change facts -- see internal/bootstrap. configRepo is
  # optional: empty means "just use the plain config.yaml below," set
  # means "fetch/refresh config.yaml from that private repo at runtime"
  # (internal/configsync) -- see -config-file vs. -config-repo in
  # cmd/verify-mseg-tester. Lives under /mseg-tester, not /etc -- see
  # internal/bootstrap's package doc for why everything this tool
  # touches lives in one directory now.
  - path: /mseg-tester/bootstrap.yaml
    permissions: "0600"
    content: |
      trunkInterface: {{.TrunkIface}}
      updateSegment: "{{.UpdateSegment}}"
      softwareRepo: "{{.SoftwareRepo}}"
      softwareRef: "{{if .SoftwareRef}}{{.SoftwareRef}}{{else}}main{{end}}"
      configRepo: "{{.ConfigRepo}}"
      configPath: "{{.ConfigPath}}"
      configRef: "{{.ConfigRef}}"
      configToken: "{{.ConfigToken}}"
      stateDir: "/mseg-tester"
      configLocalPath: "/mseg-tester/config.yaml"
{{- if .ConfigYAML}}

  # Static config.yaml provided directly via -config-file -- no private
  # repo or token needed. Lives alongside active.yaml/*.result.yaml
  # rather than under /etc -- see bootstrap.Bootstrap.ConfigLocalPath's
  # doc comment. If configRepo above is also set, this is just the
  # starting point until the first successful sync overwrites it.
  - path: /mseg-tester/config.yaml
    permissions: "0644"
    content: |
{{indent .ConfigYAML "      "}}
{{- end}}
{{- if .EnvFile}}

  # Local-only secrets (KEY=VALUE, see internal/envfile) -- resolves any
  # "${VAR}" reference in config.yaml above (e.g. report.influx.token) at
  # runtime, without that secret ever appearing in config.yaml itself.
  # 0600, never fetched from configRepo, never synced anywhere -- see
  # bootstrap.Bootstrap.EnvFile.
  - path: /mseg-tester/.env
    permissions: "0600"
    content: |
{{indent .EnvFile "      "}}
{{- end}}


  # Builds straight from a local git checkout (`go build`, not `go
  # install` -- no GitHub release, no build pipeline, no asset naming to
  # keep in sync -- see internal/selfupdate's package doc) using
  # softwareRepo/softwareRef read directly out of bootstrap.yaml above,
  # so -module-ref (which just sets softwareRef) is the ONE place that
  # needs to change to exercise an unreleased branch or commit -- no
  # separate binary-hosting side channel needed ("test without gh").
  # Retries until it succeeds: cloud-init boots this VM before there's
  # necessarily any guarantee network-online has fully settled.
  #
  # The clone+fetch+reset sequence below deliberately mirrors
  # internal/selfupdate's own steady-state update logic exactly (clone
  # only if the checkout doesn't exist yet, then always fetch+reset to
  # softwareRef) -- one mechanism, described once, not two independently
  # -- the ONLY difference here is there's no baked-in commit to compare
  # against yet, so the very first build always happens unconditionally.
  #
  # The Go toolchain itself is installed via `snap install go --classic`,
  # not an apt package or a hand-extracted tarball from go.dev -- simpler
  # and one less thing this script has to manage itself. Assumes snapd is
  # already present, which it is on stock Ubuntu Server cloud images.
  # /snap/bin also has to be on the mseg-tester.service unit's own PATH
  # for later self-updates -- see internal/deploy/mseg-tester.service.
  - path: /usr/local/sbin/mseg-tester-bootstrap.sh
    permissions: "0755"
    content: |
      #!/bin/sh
      set -e
      export HOME="${HOME:-/root}"
      export PATH="/snap/bin:$PATH"

      if ! command -v go >/dev/null 2>&1; then
        echo "mseg-tester-bootstrap: installing Go via snap" | systemd-cat -t mseg-tester-bootstrap
        i=0
        until snap install go --classic; do
          i=$((i + 1))
          echo "mseg-tester-bootstrap: snap install go failed, attempt $i, retrying in 30s" | systemd-cat -t mseg-tester-bootstrap
          sleep 30
        done
      fi

      bootstrap_yaml="/mseg-tester/bootstrap.yaml"
      software_repo=$(sed -n 's/^softwareRepo: *"\(.*\)"/\1/p' "$bootstrap_yaml")
      software_ref=$(sed -n 's/^softwareRef: *"\(.*\)"/\1/p' "$bootstrap_yaml")
      [ -n "$software_ref" ] || software_ref="main"
      repo_url="https://github.com/${software_repo}.git"
      src_dir="/mseg-tester/src"
      dest="/usr/local/bin/mseg-tester"

      echo "mseg-tester-bootstrap: fetching ${repo_url}@${software_ref} into ${src_dir}" | systemd-cat -t mseg-tester-bootstrap
      i=0
      until \
        { [ -d "$src_dir/.git" ] || git clone --depth 1 "$repo_url" "$src_dir"; } && \
        git -C "$src_dir" fetch --depth 1 origin "$software_ref" && \
        git -C "$src_dir" reset --hard FETCH_HEAD && \
        (cd "$src_dir" && go build -o "${dest}.new" ./cmd/mseg-tester)
      do
        i=$((i + 1))
        echo "mseg-tester-bootstrap: attempt $i failed, retrying in 30s" | systemd-cat -t mseg-tester-bootstrap
        sleep 30
      done
      mv "${dest}.new" "$dest"
      echo "mseg-tester-bootstrap: binary installed" | systemd-cat -t mseg-tester-bootstrap

      echo "mseg-tester-bootstrap: running deploy" | systemd-cat -t mseg-tester-bootstrap
      "$dest" deploy

      echo "mseg-tester-bootstrap: deploy done, rebooting into first cycle" | systemd-cat -t mseg-tester-bootstrap
      systemctl reboot

  - path: /etc/systemd/system/mseg-tester-bootstrap.service
    permissions: "0644"
    content: |
      [Unit]
      Description=mseg-tester: one-time clone+build+deploy (retries until it succeeds)
      After=network-online.target
      Wants=network-online.target
      ConditionPathExists=!/usr/local/bin/mseg-tester

      [Service]
      Type=oneshot
      Environment=HOME=/root
      ExecStart=/usr/local/sbin/mseg-tester-bootstrap.sh
      ExecStartPost=/usr/bin/systemctl disable mseg-tester-bootstrap.service

      [Install]
      WantedBy=multi-user.target

runcmd:
  - [mkdir, -p, /mseg-tester]
  - [systemctl, enable, mseg-tester-bootstrap.service]

power_state:
  mode: reboot
  message: "verify-mseg-tester: rebooting to start the first real cycle"
  condition: true
